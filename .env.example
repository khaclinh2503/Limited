# Database — Turso (libsql)
# Local dev: TURSO_DATABASE_URL="file:./prisma/dev.db"
# Production: lấy từ turso db show <db-name> và turso db tokens create <db-name>
TURSO_DATABASE_URL="libsql://your-db.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# NextAuth — tạo bằng: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# Google OAuth — lấy từ console.cloud.google.com
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Email admin (phân cách bằng dấu phẩy, tự động promote role ADMIN khi đăng nhập)
ADMIN_EMAILS="admin@example.com"
